# CONSULTAR TABELAS
def consultar_tabela():
    print("""
1 - Aluno
2 - Professor
3 - Disciplina
4 - Matrícula
""")

    opcao = input("Escolha a tabela: ")

    if opcao == "1":
        tabela = "aluno"
    elif opcao == "2":
        tabela = "professor"
    elif opcao == "3":
        tabela = "disciplina"
    elif opcao == "4":
        tabela = "matricula"
    else:
        print("Opção inválida!")
        return

    id_busca = input("Digite o ID: ")

    cursor.execute(f"SELECT * FROM {tabela} WHERE id = ?", (id_busca,))
    resultado = cursor.fetchone()

    print("\nRESULTADO:")
    print(resultado)

# LISTAR TABELAS
def listar_tabela():
    print("""
1 - Aluno
2 - Professor
3 - Disciplina
4 - Matrícula
""")

    opcao = input("Escolha a tabela: ")

    if opcao == "1":
        tabela = "aluno"
    elif opcao == "2":
        tabela = "professor"
    elif opcao == "3":
        tabela = "disciplina"
    elif opcao == "4":
        tabela = "matricula"
    else:
        print("Opção inválida!")
        return

    cursor.execute(f"SELECT * FROM {tabela}")

    dados = cursor.fetchall()

    print(f"\n===== TABELA {tabela.upper()} =====")

    for item in dados:
        print(item)

while True:

    print("""
========= SISTEMA ESCOLAR =========

1 - Cadastrar aluno
2 - Cadastrar professor
3 - Cadastrar disciplina
4 - Cadastrar matrícula
5 - Consultar por ID
6 - Listar tabela
0 - Sair

===================================
""")

    escolha = input("Escolha uma opção: ")

    if escolha == "1":
        cadastrar_aluno()

    elif escolha == "2":
        cadastrar_professor()

    elif escolha == "3":
        cadastrar_disciplina()

    elif escolha == "4":
        cadastrar_matricula()

    elif escolha == "5":
