# CADASTRAR MATRÍCULA
def cadastrar_matricula():
    id_aluno = input("ID do aluno: ")
    disciplina = input("Disciplina: ")
    periodo = input("Período: ")

    cursor.execute("""
    INSERT INTO matricula(id_aluno, disciplina, periodo)
